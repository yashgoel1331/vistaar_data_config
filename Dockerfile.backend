FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY Utils/ Utils/
COPY database_create/ database_create/
COPY agents/ agents/
COPY sql_functions/ sql_functions/

EXPOSE 5000

CMD ["python", "-m", "flask", "--app", "Utils.APIs:app", "run", "--host", "0.0.0.0", "--port", "5000"]
